---
import CalendlyButton from './CalendlyButton.astro';
import { useTranslations } from '../i18n/utils.js';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="cta-banner">
  <div class="container cta-banner-inner reveal">
    <div>
      <h2>{t('cta.heading')}</h2>
      <p>{t('cta.subtext')}</p>
    </div>
    <CalendlyButton label={t('btn.bookConsultation')} class="btn btn-accent" />
  </div>
</section>

<style>
  .cta-banner {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .cta-banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    background: var(--color-primary);
    border-radius: var(--radius-lg);
    padding: clamp(2rem, 4vw, 3rem) clamp(2rem, 5vw, 3.5rem);
  }

  .cta-banner-inner h2 {
    color: #ffffff;
    font-size: var(--fs-2xl);
    margin-bottom: 0.4rem;
  }

  .cta-banner-inner p {
    color: var(--color-ink-300);
    font-size: var(--fs-base);
  }

  .cta-banner-inner :global(.btn) {
    flex-shrink: 0;
  }
</style>
