---
import { SITE } from '../data/site.js';
import { useTranslations } from '../i18n/utils.js';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// ---------------------------------------------------------------------------
// This form submits via Web3Forms (https://web3forms.com) — a free,
// no-backend form relay that works perfectly on static GitHub Pages sites.
// It requires no credit card and includes a generous free tier forever.
//
// Setup (2 minutes):
//   1. Go to https://web3forms.com and enter your email to get a free
//      Access Key (no signup required).
//   2. Paste that key below, replacing "YOUR_WEB3FORMS_ACCESS_KEY".
// Until you do, the form will show a friendly message directing visitors
// to email you directly instead.
// ---------------------------------------------------------------------------
const WEB3FORMS_ACCESS_KEY = 'YOUR_WEB3FORMS_ACCESS_KEY';

const needOptions =
  lang === 'es'
    ? [
        'Búsqueda Ejecutiva',
        'Contratación de Liderazgo',
        'Reclutamiento de Finanzas',
        'Reclutamiento de Tecnología',
        'Reclutamiento de Ventas',
        'Reclutamiento de Marketing',
        'Reclutamiento de Operaciones',
        'Reclutamiento de RRHH',
        'Reclutamiento de Customer Success',
        'Contratación Remota / Internacional',
        'Otro',
      ]
    : [
        'Executive Search',
        'Leadership Hiring',
        'Finance Recruitment',
        'Technology Recruitment',
        'Sales Recruitment',
        'Marketing Recruitment',
        'Operations Recruitment',
        'HR Recruitment',
        'Customer Success Recruitment',
        'Remote / International Hiring',
        'Something else',
      ];
---

<form
  id="contactForm"
  class="contact-form"
  data-access-key={WEB3FORMS_ACCESS_KEY}
  data-msg-not-configured={t('form.notConfigured')}
  data-msg-sending={t('form.sending')}
  data-msg-success={t('form.success')}
  data-msg-error={t('form.error')}
  data-label-submit={t('form.submit')}
  novalidate
>
  <input type="hidden" name="subject" value="New consultation request — Altura Talent Partners website" />
  <input type="hidden" name="from_name" value="Altura Talent Partners Website" />
  <input type="checkbox" name="botcheck" class="visually-hidden" tabindex="-1" autocomplete="off" />

  <div class="form-row">
    <div class="form-field">
      <label for="name">{t('form.name')}</label>
      <input type="text" id="name" name="name" required autocomplete="name" />
    </div>
    <div class="form-field">
      <label for="email">{t('form.email')}</label>
      <input type="email" id="email" name="email" required autocomplete="email" />
    </div>
  </div>

  <div class="form-row">
    <div class="form-field">
      <label for="company">{t('form.company')}</label>
      <input type="text" id="company" name="company" autocomplete="organization" />
    </div>
    <div class="form-field">
      <label for="phone">{t('form.phone')} <span class="text-muted">{t('form.optional')}</span></label>
      <input type="tel" id="phone" name="phone" autocomplete="tel" />
    </div>
  </div>

  <div class="form-field">
    <label for="need">{t('form.need')}</label>
    <select id="need" name="need">
      <option value="">{t('form.needSelect')}</option>
      {needOptions.map((option) => <option>{option}</option>)}
    </select>
  </div>

  <div class="form-field">
    <label for="message">{t('form.message')}</label>
    <textarea id="message" name="message" rows="5" required placeholder={t('form.messagePlaceholder')}></textarea>
  </div>

  <button type="submit" class="btn btn-accent btn-block" id="formSubmit">
    <span class="btn-label">{t('form.submit')}</span>
  </button>

  <p class="form-status" id="formStatus" role="status" aria-live="polite"></p>

  <p class="form-alt">
    {t('form.preferEmail')} <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
  </p>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--color-white);
    border: 1px solid var(--color-ink-200);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    box-shadow: var(--shadow-md);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form-field label {
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--color-primary);
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    border: 1px solid var(--color-ink-200);
    border-radius: var(--radius-sm);
    padding: 0.8rem 0.95rem;
    font-size: var(--fs-sm);
    background: var(--color-gray-50);
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    background: var(--color-white);
    box-shadow: var(--shadow-focus);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-status {
    font-size: var(--fs-sm);
    min-height: 1.2em;
  }

  .form-status[data-state='success'] {
    color: var(--color-success);
  }

  .form-status[data-state='error'] {
    color: #b91c1c;
  }

  .form-alt {
    font-size: var(--fs-xs);
    color: var(--color-ink-500);
    text-align: center;
  }

  .form-alt a {
    color: var(--color-accent);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const status = document.getElementById('formStatus');
  const submitBtn = document.getElementById('formSubmit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status || !submitBtn) return;

    const accessKey = form.dataset.accessKey;
    if (!accessKey || accessKey === 'YOUR_WEB3FORMS_ACCESS_KEY') {
      status.dataset.state = 'error';
      status.textContent = form.dataset.msgNotConfigured ?? '';
      return;
    }

    const formData = new FormData(form);
    formData.append('access_key', accessKey);

    submitBtn.disabled = true;
    const label = submitBtn.querySelector('.btn-label');
    const originalLabel = label?.textContent ?? form.dataset.labelSubmit ?? '';
    if (label) label.textContent = form.dataset.msgSending ?? '';

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: formData,
      });
      const result = await response.json();

      if (result.success) {
        status.dataset.state = 'success';
        status.textContent = form.dataset.msgSuccess ?? '';
        form.reset();
      } else {
        throw new Error(result.message || 'Submission failed');
      }
    } catch (err) {
      status.dataset.state = 'error';
      status.textContent = form.dataset.msgError ?? '';
    } finally {
      submitBtn.disabled = false;
      if (label) label.textContent = originalLabel;
    }
  });
</script>
