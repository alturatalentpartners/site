---
import Icon from './Icon.astro';

interface Props {
  question: string;
  answer: string;
}
const { question, answer } = Astro.props;
---

<details class="faq-item reveal">
  <summary>
    <span>{question}</span>
    <span class="faq-icon"><Icon name="arrowRight" size={16} /></span>
  </summary>
  <p>{answer}</p>
</details>

<style>
  .faq-item {
    border-bottom: 1px solid var(--color-ink-200);
    padding-block: 1.5rem;
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    cursor: pointer;
    list-style: none;
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--color-primary);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: var(--radius-full);
    background: var(--color-gray-50);
    color: var(--color-primary);
    flex-shrink: 0;
    transition: transform 0.3s var(--ease-out), background 0.3s ease;
    transform: rotate(0deg);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(90deg);
    background: var(--color-accent);
    color: #fff;
  }

  .faq-item p {
    margin-top: 1rem;
    font-size: var(--fs-sm);
    max-width: 68ch;
    line-height: 1.7;
  }
</style>
