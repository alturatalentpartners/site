---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { SITE, NAV_LINKS } from '../data/site.js';

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container footer-top">
    <div class="footer-brand">
      <a href={base} aria-label="Altura Talent Partners — home">
        <Logo theme="light" />
      </a>
      <p>
        A boutique executive search and strategic recruiting firm helping growing
        companies across North America, LATAM and Europe build exceptional teams.
      </p>
      <a href={SITE.linkedin} class="footer-social" target="_blank" rel="noopener noreferrer" aria-label="Altura Talent Partners on LinkedIn">
        <Icon name="linkedin" size={20} />
      </a>
    </div>

    <div class="footer-col">
      <h3>Navigate</h3>
      <ul>
        {NAV_LINKS.map((link) => (
          <li><a href={`${base}${link.href.replace(/^\//, '')}`}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h3>Company</h3>
      <ul>
        <li><a href={`${base}privacy-policy/`}>Privacy Policy</a></li>
        <li><a href={`${base}terms/`}>Terms of Service</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3>Get in touch</h3>
      <ul>
        <li>
          <a href={SITE.phoneHref}>
            <Icon name="phone" size={16} /> {SITE.phone}
          </a>
        </li>
        <li>
          <a href={`mailto:${SITE.email}`}>
            <Icon name="mail" size={16} /> {SITE.email}
          </a>
        </li>
        <li>
          <span class="footer-location">
            <Icon name="pin" size={16} /> Serving North America, LATAM &amp; Europe
          </span>
        </li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>&copy; {year} Altura Talent Partners. All rights reserved.</p>
    <p class="footer-note">Executive search &amp; strategic recruiting, built for growing companies.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: var(--color-ink-300);
    padding-block: 4.5rem 2rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.3fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-brand p {
    margin-top: 1.25rem;
    max-width: 32ch;
    color: var(--color-ink-300);
    font-size: var(--fs-sm);
    line-height: 1.7;
  }

  .footer-social {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #ffffff;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .footer-social:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .footer-col h3 {
    color: #ffffff;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .footer-col a,
  .footer-location {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--fs-sm);
    color: var(--color-ink-300);
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: #ffffff;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 2rem;
    font-size: var(--fs-xs);
    color: var(--color-ink-500);
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .footer-top {
      grid-template-columns: 1fr;
    }
  }
</style>
