---
import Icon from './Icon.astro';

interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const copy =
  lang === 'es'
    ? { shortlist: 'Terna entregada', finalists: '4 finalistas evaluados', offer: 'Oferta aceptada', role: 'VP Finanzas · Semana 6' }
    : { shortlist: 'Shortlist delivered', finalists: '4 vetted finalists', offer: 'Offer accepted', role: 'VP Finance · Week 6' };
---

<div class="hero-graphic" aria-hidden="true">
  <div class="hg-panel">
    <svg class="hg-grid" viewBox="0 0 400 320" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotgrid" width="24" height="24" patternUnits="userSpaceOnUse">
          <circle cx="1.5" cy="1.5" r="1.5" fill="#E2E8F0" />
        </pattern>
      </defs>
      <rect width="400" height="320" fill="url(#dotgrid)" />
      <path d="M20 250 L110 190 L190 220 L280 110 L380 60" stroke="#2563EB" stroke-width="3" stroke-linecap="round" fill="none" />
      <path d="M20 250 L110 190 L190 220 L280 110 L380 60 L380 320 L20 320 Z" fill="#2563EB" fill-opacity="0.06" stroke="none" />
      <circle cx="20" cy="250" r="5" fill="#0F172A" />
      <circle cx="110" cy="190" r="5" fill="#0F172A" />
      <circle cx="190" cy="220" r="5" fill="#0F172A" />
      <circle cx="280" cy="110" r="5" fill="#B08D57" />
      <circle cx="380" cy="60" r="6" fill="#B08D57" />
    </svg>

    <div class="hg-card hg-card--top">
      <span class="hg-icon"><Icon name="check" size={16} /></span>
      <div>
        <strong>{copy.shortlist}</strong>
        <span>{copy.finalists}</span>
      </div>
    </div>

    <div class="hg-card hg-card--bottom">
      <span class="hg-icon hg-icon--gold"><Icon name="handshake" size={16} /></span>
      <div>
        <strong>{copy.offer}</strong>
        <span>{copy.role}</span>
      </div>
    </div>
  </div>
</div>

<style>
  .hero-graphic {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .hg-panel {
    position: relative;
    width: 100%;
    max-width: 440px;
    aspect-ratio: 5 / 4;
    background: var(--color-white);
    border: 1px solid var(--color-ink-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .hg-grid {
    width: 100%;
    height: 100%;
  }

  .hg-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: var(--color-white);
    border: 1px solid var(--color-ink-200);
    border-radius: var(--radius-sm);
    padding: 0.65rem 0.9rem;
    box-shadow: var(--shadow-md);
    font-size: var(--fs-2xs);
  }

  .hg-card strong {
    display: block;
    font-size: var(--fs-xs);
    color: var(--color-primary);
    font-weight: 600;
  }

  .hg-card span {
    color: var(--color-ink-500);
  }

  .hg-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: var(--radius-full);
    background: rgba(37, 99, 235, 0.1);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .hg-icon--gold {
    background: rgba(176, 141, 87, 0.15);
    color: var(--color-gold);
  }

  .hg-card--top {
    top: 12%;
    left: 6%;
  }

  .hg-card--bottom {
    bottom: 10%;
    right: 6%;
  }

  @media (max-width: 560px) {
    .hg-card {
      display: none;
    }
  }
</style>
