---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { NAV_ROUTES } from '../data/site.js';
import { useTranslations, localizePath, getRouteFromUrl } from '../i18n/utils.js';

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname.replace(base, '/').replace(/\/+/g, '/');

const otherLang = lang === 'en' ? 'es' : 'en';
const route = getRouteFromUrl(Astro.url);
const switchHref = `${base}${localizePath(route, otherLang).replace(/^\//, '')}`;

const homeHref = `${base}${localizePath('', lang).replace(/^\//, '')}`;
const contactHref = `${base}${localizePath('contact/', lang).replace(/^\//, '')}`;
---

<header class="navbar" id="navbar">
  <div class="container navbar-inner">
    <a href={homeHref} class="navbar-brand" aria-label="Altura Talent Partners">
      <Logo />
    </a>

    <nav class="navbar-nav" aria-label="Primary">
      <ul>
        {NAV_ROUTES.map((route) => {
          const href = `${base}${localizePath(`${route}/`, lang).replace(/^\//, '')}`;
          const isActive = currentPath === localizePath(`${route}/`, lang);
          return (
            <li>
              <a href={href} aria-current={isActive ? 'page' : undefined}>{t(`nav.${route}`)}</a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="navbar-actions">
      <a href={switchHref} class="lang-switch">{t('nav.langSwitch')}</a>
      <a href={contactHref} class="btn btn-primary">{t('nav.cta')}</a>
    </div>

    <button
      class="navbar-toggle"
      id="navToggle"
      aria-expanded="false"
      aria-controls="mobileMenu"
      aria-label={t('nav.openMenu')}
      data-label-open={t('nav.openMenu')}
      data-label-close={t('nav.closeMenu')}
    >
      <Icon name="menu" size={22} />
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    <ul>
      {NAV_ROUTES.map((route) => (
        <li><a href={`${base}${localizePath(`${route}/`, lang).replace(/^\//, '')}`}>{t(`nav.${route}`)}</a></li>
      ))}
    </ul>
    <a href={switchHref} class="lang-switch lang-switch-mobile">{t('nav.langSwitch')}</a>
    <a href={contactHref} class="btn btn-primary btn-block">{t('nav.cta')}</a>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .navbar.is-scrolled {
    border-bottom-color: var(--color-ink-200);
    box-shadow: 0 1px 0 rgba(15, 23, 42, 0.02);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.1rem;
  }

  .navbar-brand {
    display: flex;
  }

  .navbar-nav ul {
    display: flex;
    gap: 2.25rem;
  }

  .navbar-nav a {
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-ink-700);
    transition: color 0.2s ease;
    position: relative;
  }

  .navbar-nav a:hover,
  .navbar-nav a[aria-current='page'] {
    color: var(--color-primary);
  }

  .navbar-nav a[aria-current='page']::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -8px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .navbar-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .lang-switch {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-ink-500);
    border: 1px solid var(--color-ink-200);
    border-radius: var(--radius-full);
    padding: 0.4rem 0.85rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .lang-switch:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .lang-switch-mobile {
    align-self: flex-start;
  }

  .navbar-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--color-primary);
    padding: 0.4rem;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.5rem clamp(1.25rem, 4vw, 3rem) 2rem;
    border-top: 1px solid var(--color-ink-200);
    background: var(--color-white);
  }

  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .mobile-menu ul a {
    font-size: var(--fs-lg);
    font-weight: 500;
    color: var(--color-primary);
  }

  .mobile-menu.is-open {
    display: flex;
  }

  @media (max-width: 900px) {
    .navbar-nav,
    .navbar-actions {
      display: none;
    }
    .navbar-toggle {
      display: inline-flex;
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('mobileMenu');

  const onScroll = () => {
    if (window.scrollY > 8) {
      navbar?.classList.add('is-scrolled');
    } else {
      navbar?.classList.remove('is-scrolled');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
    toggle.setAttribute('aria-label', isOpen ? toggle.dataset.labelClose ?? '' : toggle.dataset.labelOpen ?? '');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
