---
interface Props {
  number: string;
  title: string;
  description: string;
  isLast?: boolean;
}
const { number, title, description, isLast = false } = Astro.props;
---

<div class="process-step reveal" data-last={isLast}>
  <div class="process-marker">
    <span>{number}</span>
    {!isLast && <span class="process-line" aria-hidden="true"></span>}
  </div>
  <div class="process-content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
  .process-step {
    display: flex;
    gap: 1.5rem;
  }

  .process-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .process-marker span:first-child {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    font-weight: 600;
    font-size: var(--fs-sm);
  }

  .process-line {
    flex: 1;
    width: 1px;
    background: var(--color-ink-300);
    margin-block: 0.75rem;
    min-height: 2rem;
  }

  .process-content {
    padding-bottom: 2.75rem;
  }

  .process-content h3 {
    margin-bottom: 0.5rem;
  }

  .process-content p {
    font-size: var(--fs-sm);
    max-width: 46ch;
  }
</style>
