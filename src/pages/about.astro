---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { SITE } from '../data/site.js';

const base = import.meta.env.BASE_URL;

const isNot = [
  'A staffing agency working high volume, low-context roles',
  'A mass recruiting operation optimizing for speed over fit',
  'A freelance recruiter working one search at a time',
];

const values = [
  {
    icon: 'compass',
    title: 'Quality Over Volume',
    description: 'We run fewer searches at a time so every one of them gets the attention a real hiring decision deserves.',
  },
  {
    icon: 'bulb',
    title: 'Business Understanding',
    description: 'We ask about strategy and org structure before we ask about years of experience — context shapes a better search.',
  },
  {
    icon: 'scale',
    title: 'Discretion by Default',
    description: 'Leadership searches are often confidential. We treat every engagement with the same care, whether it’s public or not.',
  },
  {
    icon: 'handshake',
    title: 'Built for the Long Term',
    description: 'We measure success by whether a hire is still thriving a year later, not just whether an offer got signed.',
  },
];

const stats = [
  { number: '3', label: 'Regions served — North America, LATAM, Europe' },
  { number: '15+', label: 'Recruiting specialties across functions' },
  { number: '13', label: 'Industries we actively recruit within' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Altura Talent Partners',
  url: `${SITE.url}/about/`,
};
---

<Layout
  title="About Us"
  description="Altura Talent Partners is a boutique executive search and strategic recruiting firm — not a staffing agency. Learn how we work with founders and leadership teams."
  schema={schema}
>
  <section class="page-hero section-sm">
    <div class="container container-narrow text-center">
      <span class="eyebrow">About Altura</span>
      <h1>A search partner, not a résumé pipeline</h1>
      <p class="lede mx-auto">
        Altura Talent Partners is a boutique executive search and strategic
        recruiting firm. We help startups, scale-ups and established companies
        hire exceptional professionals — with the judgment and discretion those
        decisions deserve.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container who-grid">
      <div class="who-copy">
        <span class="eyebrow">Who We Are</span>
        <h2>We operate as a strategic hiring partner</h2>
        <p>
          Every company we work with is trying to solve the same underlying
          problem: they have a role that matters too much to get wrong, and
          not enough internal bandwidth to run the kind of search it deserves.
          That&rsquo;s the gap we fill.
        </p>
        <p>
          We work internationally, recruiting remote and onsite talent across
          North America, LATAM and Europe. Our process is built around
          business understanding and long-term fit — not speed for its own
          sake.
        </p>
      </div>
      <div class="who-not card">
        <h3>What we are not</h3>
        <ul>
          {isNot.map((item) => (
            <li><Icon name="close" size={16} /><span>{item}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-gray">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What We Value</span>
        <h2>The principles behind every search</h2>
      </div>
      <div class="grid grid-4">
        {values.map((v) => (
          <div class="value-card reveal">
            <span class="value-icon"><Icon name={v.icon} size={22} /></span>
            <h3>{v.title}</h3>
            <p>{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container reach-grid">
      <div>
        <span class="eyebrow">Global Reach</span>
        <h2>North America, LATAM and Europe — remote or onsite</h2>
        <p class="lede">
          Growing companies rarely hire from a single city anymore. We recruit
          talent wherever it lives, with region-specific knowledge of
          compensation norms, talent pools and hiring practices — so an
          international search feels as considered as a local one.
        </p>
      </div>
      <div class="stats-row">
        {stats.map((s) => (
          <div class="stat-block reveal">
            <span class="stat-number">{s.number}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-gray cta-section">
    <div class="container text-center">
      <h2>Have a role that needs the right search partner?</h2>
      <p class="lede mx-auto">Tell us what you&rsquo;re hiring for and we&rsquo;ll walk you through how we&rsquo;d approach it.</p>
      <a href={`${base}contact/`} class="btn btn-primary">Book a Consultation</a>
    </div>
  </section>
</Layout>

<style>
  .who-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: start;
  }

  .who-copy h2 {
    margin: 1rem 0 1.25rem;
  }

  .who-copy p {
    margin-bottom: 1.1rem;
  }

  .who-not h3 {
    margin-bottom: 1.25rem;
  }

  .who-not ul {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .who-not li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: var(--fs-sm);
    color: var(--color-ink-700);
  }

  .who-not li :global(svg) {
    flex-shrink: 0;
    margin-top: 3px;
    color: #b91c1c;
  }

  .value-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background: var(--color-white);
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .value-card h3 {
    font-size: var(--fs-lg);
    margin-bottom: 0.6rem;
  }

  .value-card p {
    font-size: var(--fs-sm);
  }

  .reach-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: center;
  }

  .reach-grid h2 {
    margin: 1rem 0 1.25rem;
  }

  .stats-row {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    border-left: 2px solid var(--color-ink-200);
    padding-left: 2rem;
  }

  .stat-number {
    display: block;
    font-size: var(--fs-3xl);
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: var(--fs-sm);
    color: var(--color-ink-500);
  }

  .cta-section h2 {
    margin-bottom: 1rem;
  }

  .cta-section .lede {
    margin-bottom: 2rem;
  }

  @media (max-width: 900px) {
    .who-grid,
    .reach-grid {
      grid-template-columns: 1fr;
    }
    .stats-row {
      border-left: none;
      padding-left: 0;
      border-top: 2px solid var(--color-ink-200);
      padding-top: 1.75rem;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 2rem;
    }
  }
</style>
