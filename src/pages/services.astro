---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { SERVICES } from '../data/services.js';
import { SITE } from '../data/site.js';

const base = import.meta.env.BASE_URL;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: SERVICES.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.title,
    url: `${SITE.url}/services/#${s.slug}`,
  })),
};
---

<Layout
  title="Services"
  description="Executive search, strategic recruiting and specialist hiring across finance, technology, sales, marketing, operations, HR and more — for growing companies worldwide."
  schema={schema}
>
  <section class="page-hero section-sm">
    <div class="container container-narrow text-center">
      <span class="eyebrow">Services</span>
      <h1>Search and recruiting for the roles that matter most</h1>
      <p class="lede mx-auto">
        From first leadership hire to a full functional build-out, we recruit
        across the disciplines that determine whether a growing company scales
        well or stalls.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-list">
        {SERVICES.map((service) => (
          <article class="service-block reveal" id={service.slug}>
            <span class="service-block-icon"><Icon name={service.icon} size={24} /></span>
            <div class="service-block-body">
              <h2>{service.title}</h2>
              <p>{service.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-gray cta-section">
    <div class="container text-center">
      <h2>Don&rsquo;t see exactly what you need?</h2>
      <p class="lede mx-auto">Most searches don&rsquo;t fit neatly into one category. Tell us what you&rsquo;re hiring for and we&rsquo;ll tell you honestly whether we&rsquo;re the right fit.</p>
      <a href={`${base}contact/`} class="btn btn-primary">Book a Consultation</a>
    </div>
  </section>
</Layout>

<style>
  .services-list {
    display: flex;
    flex-direction: column;
    max-width: 860px;
    margin-inline: auto;
  }

  .service-block {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 1.5rem;
    padding-block: 2.25rem;
    border-bottom: 1px solid var(--color-ink-200);
    scroll-margin-top: 6rem;
  }

  .service-block:first-child {
    padding-top: 0;
  }

  .service-block-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-sm);
    background: var(--color-gray-50);
    color: var(--color-accent);
  }

  .service-block-body h2 {
    font-size: var(--fs-xl);
    margin-bottom: 0.6rem;
  }

  .service-block-body p {
    max-width: 62ch;
  }

  .cta-section h2 {
    margin-bottom: 1rem;
  }

  .cta-section .lede {
    margin-bottom: 2rem;
  }

  @media (max-width: 560px) {
    .service-block {
      grid-template-columns: 1fr;
    }
  }
</style>
