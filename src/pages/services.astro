---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import CTABanner from '../components/CTABanner.astro';
import { SERVICES, SERVICES_ES } from '../data/services.js';
import { SITE } from '../data/site.js';
import { localizePath } from '../i18n/utils.js';

const lang = (Astro.currentLocale ?? 'en') as 'en' | 'es';
const services = lang === 'es' ? SERVICES_ES : SERVICES;

const copy = {
  en: {
    metaTitle: 'Services',
    metaDescription: 'Executive search, strategic recruiting and specialist hiring across finance, technology, sales, marketing, operations, HR and more — for growing companies worldwide.',
    eyebrow: 'Services',
    h1: 'Search and recruiting for the roles that matter most',
    lede: 'From first leadership hire to a full functional build-out, we recruit across the disciplines that determine whether a growing company scales well or stalls.',
  },
  es: {
    metaTitle: 'Servicios',
    metaDescription: 'Búsqueda ejecutiva, reclutamiento estratégico y contratación de especialistas en finanzas, tecnología, ventas, marketing, operaciones, RRHH y más — para empresas en crecimiento en todo el mundo.',
    eyebrow: 'Servicios',
    h1: 'Búsqueda y reclutamiento para los roles que más importan',
    lede: 'Desde tu primera contratación de liderazgo hasta armar un área funcional completa, reclutamos en las disciplinas que definen si una empresa en crecimiento escala bien o se estanca.',
  },
}[lang];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: services.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: s.title,
    url: `${SITE.url}${localizePath('services/', lang)}#${s.slug}`,
  })),
};
---

<Layout title={copy.metaTitle} description={copy.metaDescription} schema={schema}>
  <section class="page-hero section-sm">
    <div class="container container-narrow text-center">
      <span class="eyebrow">{copy.eyebrow}</span>
      <h1>{copy.h1}</h1>
      <p class="lede mx-auto">{copy.lede}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="services-list">
        {services.map((service) => (
          <article class="service-block reveal" id={service.slug}>
            <span class="service-block-icon"><Icon name={service.icon} size={24} /></span>
            <div class="service-block-body">
              <h2>{service.title}</h2>
              <p>{service.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTABanner lang={lang} />
</Layout>

<style>
  .services-list {
    display: flex;
    flex-direction: column;
    max-width: 860px;
    margin-inline: auto;
  }

  .service-block {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 1.5rem;
    padding-block: 2.25rem;
    border-bottom: 1px solid var(--color-ink-200);
    scroll-margin-top: 6rem;
  }

  .service-block:first-child {
    padding-top: 0;
  }

  .service-block-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-sm);
    background: var(--color-gray-50);
    color: var(--color-accent);
  }

  .service-block-body h2 {
    font-size: var(--fs-xl);
    margin-bottom: 0.6rem;
  }

  .service-block-body p {
    max-width: 62ch;
  }

  @media (max-width: 560px) {
    .service-block {
      grid-template-columns: 1fr;
    }
  }
</style>
